generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
enum Role {
  ADMIN
  ENSEIGNANT
  ELEVE
}

enum SEXE {
  M
  F
}
enum Redoublant {
  oui
  non
}
enum Bourse {
  oui
  non
}
enum Affecte {
  oui
  non
}
enum Justifie {
  oui
  non
}
model User {
  id         Int     @id @default(autoincrement())
  login      String  @unique
  mot_passe  String
  role       Role

  eleve       Eleve?
  enseignant  Enseignant?
  admin Administrateur ?
}
model Eleve {
  matricule   String   @id @unique
  nom         String
  prenom      String
  dateNaissance DateTime?
  lieuNaissance String ?
  sexe SEXE ? 
  affecte Affecte  @default(non) 
  boursier Bourse  @default(non)
  redoublant Redoublant  @default(non)
  nationalite String  @default("Ivoirienne") 

  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id])

  inscriptions Inscription[]   // ✅ ajout
  historique  ResultatTrimestre[]
  absence     Absence[]
}

model Enseignant {
  matricule     String   @id  
  nom           String
  prenom        String
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id])
  affectation Affectation[]
  etablissements EnseignantEtablissement[]
}

model Administrateur {
  id              Int            @id @default(autoincrement())
  nom             String
  prenom          String
  email           String         @unique
  userId Int      @unique
  user User @relation(fields: [userId], references: [id])
  etablissement   Etablissement ?
}

model Classe {
  id           Int       @id @default(autoincrement())
  libelle      String
  idEtablissement Int ?
  etablissement    Etablissement? @relation(fields: [idEtablissement], references: [id])
  inscriptions Inscription[] // IMPORTANT
  affectation Affectation[]
}

model Matiere {
  id                Int       @id @default(autoincrement())
  nom               String
  etablissement_id  Int    @unique
  etablissement     Etablissement @relation(fields: [etablissement_id], references: [id])
  notes             Note[]
  affectation       Affectation[]
  @@unique([nom, etablissement_id]) //clé unique par établissement
}

model Trimestre {
  id_trimestre Int     @id @default(autoincrement())
  libelle      String
  date_debut DateTime 
  date_fin DateTime 
  actif Boolean
  notes        Note[]
  absence Absence[]
  resultatTrimestre ResultatTrimestre[]
}

model Note {
  id               Int      @id @default(autoincrement())
  valeur           Float
  typeEvaluation   String   // Interro, Devoir, Examen
  coefficient      Int      @default(1)
  id_inscription   Int
  id_matiere       Int
  id_trimestre     Int

  inscription Inscription @relation(fields: [id_inscription], references: [id])
  matiere     Matiere     @relation(fields: [id_matiere], references: [id])
  trimestre   Trimestre   @relation(fields: [id_trimestre], references: [id_trimestre])

  @@index([id_inscription])
  @@index([id_matiere])
  @@index([id_trimestre])
}

