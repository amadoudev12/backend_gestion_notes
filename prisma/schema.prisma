model Affectation {
  id           Int @id @default(autoincrement())
  id_classe    Int
  id_matiere   Int
  id_prof      String
  coefficient  Int

  classe     Classe     @relation(fields: [id_classe], references: [id])
  matiere    Matiere    @relation(fields: [id_matiere], references: [id])
  enseignant Enseignant @relation(fields: [id_prof], references: [matricule])

  @@unique([id_classe, id_matiere])
}
model ResultatTrimestre {
  id               Int      @id @default(autoincrement())
  eleveId          String
  idtrimestre      Int
  id_annee         Int   // ✅ ajouté
  moyenneGenerale  Float
  decision         String
  rang             Int
  mention          String?

  eleve       Eleve @relation(fields: [eleveId], references: [matricule])
  trimestre   Trimestre @relation(fields: [idtrimestre], references: [id_trimestre])
  annee       AnneeAcademique @relation(fields: [id_annee], references: [id])

  @@unique([eleveId, idtrimestre, id_annee])
}

model Absence {
  id               Int      @id @default(autoincrement())
  nombre            Int
  justifiee        Justifie @default(oui)
  // Relation avec élève
  matricule_eleve  String
  eleve            Eleve    @relation(fields: [matricule_eleve], references: [matricule])
  // Relation avec trimestre
  trimestreId      Int
  trimestre        Trimestre @relation(fields: [trimestreId], references: [id_trimestre])

  createdAt        DateTime @default(now())
  @@unique([matricule_eleve, trimestreId])
}

model Etablissement {
  id      Int    @id @default(autoincrement()) @unique
  nom     String
  adresse String
  phone   String?
  email   String?
  code    String
  statut  String
  directeur String
  admin_id Int @unique
  classe Classe[] 
  Administrateur  Administrateur @relation(fields: [admin_id], references: [id])
  enseignants   EnseignantEtablissement[]
  Matieres Matiere[]
}


model AnneeAcademique {
  id            Int      @id @default(autoincrement())
  libelle       String   // ex: 2025-2026
  date_debut    DateTime
  date_fin      DateTime
  actif         Boolean  @default(false)

  inscriptions  Inscription[]
  resultats     ResultatTrimestre[]
}

model Inscription {
  id                    Int      @id @default(autoincrement())
  matricule_eleve       String
  id_classe             Int
  id_annee_academique   Int
  dateInscription       DateTime @default(now())
  eleve   Eleve   @relation(fields: [matricule_eleve], references: [matricule])
  classe  Classe  @relation(fields: [id_classe], references: [id])
  annee   AnneeAcademique @relation(fields: [id_annee_academique], references: [id])
  notes Note[]
  @@unique([matricule_eleve, id_annee_academique])
}

model EnseignantEtablissement {
  id               Int @id @default(autoincrement())
  enseignant_id    String
  etablissement_id Int

  enseignant    Enseignant @relation(fields: [enseignant_id], references: [matricule])
  etablissement Etablissement @relation(fields: [etablissement_id], references: [id])

  @@unique([enseignant_id, etablissement_id])
}