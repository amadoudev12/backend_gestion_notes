<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Fiche de Notes - BTS 2 IDA</title>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: Arial, sans-serif;
        font-size: 11px;
        margin: 20px;
        color: #000;
    }

    .container {
        max-width: 950px;
        margin: auto;
    }

    .print-btn {
        text-align: center;
        margin-bottom: 16px;
    }

    .print-btn button {
        padding: 8px 20px;
        font-size: 13px;
        cursor: pointer;
        background-color: #2563eb;
        color: white;
        border: none;
        border-radius: 4px;
    }

    @media print {
        .print-btn { display: none; }
        body { margin: 10px; }
    }

    /* ── EN-TÊTE ── */
    .header-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 6px;
    }

    .logo-block {
        text-align: center;
        font-weight: bold;
        font-size: 10px;
        border: 2px solid #000;
        padding: 4px 10px;
        min-width: 80px;
    }

    .logo-block .logo-title {
        font-size: 16px;
        font-weight: 900;
        letter-spacing: 1px;
    }

    .logo-block .logo-sub {
        font-size: 7px;
        font-weight: normal;
        max-width: 90px;
    }

    .center-title {
        text-align: center;
        flex: 1;
        padding: 0 20px;
    }

    .center-title h2 {
        font-size: 14px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* ── LIGNES D'INFO ── */
    .info-section {
        border: 1px solid #000;
        margin-bottom: 4px;
    }

    .info-row {
        display: flex;
        border-bottom: 1px solid #000;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-cell {
        padding: 3px 8px;
        border-right: 1px solid #000;
        flex: 1;
        font-size: 10px;
    }

    .info-cell:last-child {
        border-right: none;
    }

    .info-cell .label {
        font-size: 8px;
        text-transform: uppercase;
        color: #555;
    }

    .info-cell .value {
        font-weight: bold;
    }

    /* ── TABLEAU DE NOTES ── */
    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 6px;
    }

    table, th, td {
        border: 1px solid #000;
    }

    thead tr th {
        background-color: #e8e8e8;
        font-size: 9px;
        font-weight: bold;
        text-align: center;
        padding: 4px 2px;
        text-transform: uppercase;
    }

    tbody tr td {
        padding: 3px 4px;
        text-align: center;
        font-size: 10px;
    }

    tbody tr:nth-child(even) {
        background-color: #fafafa;
    }

    td.nom {
        text-align: left;
        font-size: 9.5px;
        white-space: nowrap;
    }

    td.note {
        min-width: 35px;
    }

    td.moyenne {
        font-weight: bold;
    }

    td.contact {
        font-size: 9px;
        white-space: nowrap;
    }

    td.signature-cell {
        min-width: 60px;
        height: 22px;
    }

    /* ── PIED DE PAGE ── */
    .footer {
        margin-top: 20px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        font-size: 11px;
    }

    .footer .date-line {
        font-style: italic;
    }

    .footer .prof-sig {
        text-align: center;
    }

    .footer .prof-sig p {
        margin-bottom: 15px;
        font-weight: bold;
        text-transform: uppercase;
        font-size: 10px;
    }
</style>
</head>
<body>

<% 
    const now = new Date();
    const day = now.getDate();
    const month = now.getMonth() + 1; // Les mois commencent à 0
    const year = now.getFullYear();
    const dateDay = `${day}/${month}/${year}`;

    let maxNotes = notes[0][0].notes.length;

    notes.forEach((noteEleve) => {
        if (noteEleve[0].notes.length > maxNotes) {
            maxNotes = noteEleve[0].notes.length;
        }
    });
%>
    
<div class="container">

    <div class="print-btn">
        <button onclick="window.print()">🖨️ Imprimer</button>
    </div>

    <!-- EN-TÊTE -->
    <div class="header-row">
        <!-- <div class="logo-block">
            <div class="logo-title">HETEC</div>
            <div class="logo-sub">ÉCOLE SUPÉRIEURE DES</div>
        </div> -->

        <div class="center-title">
            <h2>FICHE DE NOTES <%= classe %> </h2>  
        </div>

        <!-- <div class="logo-block">
            <div class="logo-title">Logo</div>
            <div class="logo-sub"></div>
        </div> -->
    </div>

    <!-- INFOS DOCUMENT -->
    <div class="info-section">
        <div class="info-row">
            <div class="info-cell">
                <span class="label">ministre de l'éducation nationale et de l'alphabétisation</span>
            </div>
            <div class="info-cell">
                <span class="label">Année Scolaire :</span>
                <span class="value"> 2025 - 2026</span>
            </div>
        </div>
        <div class="info-row">
            <div class="info-cell">
                <span class="label">Matière :</span>
                <span class="value"> <%= matiere %></span>
            </div>
            <div class="info-cell">
                <span class="label">Trimestre: </span>
                <span class="value">  <%= trimestre %> </span>
            </div>
        </div>
        <div class="info-row">
            <div class="info-cell" style="flex:2;">
                <span class="label">Établissement :</span>
                <span class="value"><%= etablissement %></span>
            </div>
            <div class="info-cell">
                <span class="label">Classe :</span>
                <span class="value"> <%= classe %> </span>
            </div>
        </div>
    </div>

    <!-- TABLEAU -->
    <table>
        <thead>
            <tr>
                <th style="width:25px;">N°</th>
                <th style="min-width:160px;">Nom et Prénoms</th>
                <% for (let i=1; i<= maxNotes; i++){%>
                        <th class="note">Note <%= i %> </th>
                <% }%>
                <th style="min-width:55px;">Moy /20</th>
                <th style="min-width:70px;">Signature</th>
                <th style="min-width:90px;">Contact</th>
            </tr>
        </thead>
        <tbody>
        <% notes.forEach((eleve, index) => {
            const n = eleve[0].notes || [];
            let total = 0, totalCoef = 0;
            n.forEach(note => {
                if (note && note.valeur !== undefined) {
                    total += note.valeur * (note.coefficient || 1);
                    totalCoef += (note.coefficient || 1);
                }
            });
            const moyenne = totalCoef > 0 ? (total / totalCoef).toFixed(2) : '';
        %>
            <tr>
                <td><%= index + 1 %></td>
                <td class="nom"><%= eleve[0].infos.nom %></td>
                    <% for (let i = 0; i < maxNotes; i++) { %>
                        <td class="note">
                            <%= (n[i] && n[i].valeur !== undefined) ? n[i].valeur : '' %>
                        </td>
                    <% } %>
                <td class="moyenne"><%= moyenne %></td>
                <td class="signature-cell"></td>
                <td class="contact"></td>
            </tr>
        <% }) %>

        <!-- Lignes vides si moins de 34 élèves -->
        <!-- <% for (let i = notes.length; i < 34; i++) { %>
            <tr>
                <td><%= i + 1 %></td>
                <td class="nom">&nbsp;</td>
                <td></td><td></td><td></td><td></td>
                <td></td><td class="signature-cell"></td><td></td>
            </tr>
        <% } %> -->
        </tbody>
    </table>

    <!-- PIED DE PAGE -->
    <div class="footer">
        <div class="date-line">
            Fait à Abidjan, le <%= dateDay %>
        </div>
        <div class="prof-sig">
            <p>Nom et Signature du Professeur :</p>
            <p><%= infosProf %></p>
            <div style="width:200px; border-bottom:1px solid #000; margin:0 auto;"></div>
        </div>
    </div>

</div>
</body>
</html>
